generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DELIVERY
}

enum DeliveryType {
  GATE
  HOSTEL
}

enum OrderStatus {
  ORDER_CONFIRMED
  REACHED_CAMPUS
  DELIVERED
  CANCELLED
}

enum OrderSource {
  CUSTOMER_ONLINE
  ADMIN_MANUAL
}

enum OrderSlot {
  AFTERNOON
  NIGHT
}

enum PaymentStatus {
  PENDING
  PAID_ONLINE
  PAID_MANUALLY
  FAILED
  REFUNDED
  UNPAID
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  TELEGRAM
}

enum NotificationEvent {
  ORDER_CREATED
  REACHED_CAMPUS
  DELIVERED
}

enum NotificationStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  phone         String?
  role          UserRole      @default(DELIVERY)
  passwordHash  String
  active        Boolean       @default(true)
  assignedHostelBlocks String[] @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  appSessions   AppSession[]
  deliveries    Order[]       @relation("DeliveredBy")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Restaurant {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  courses     Course[]
  menuItems   MenuItem[]
  orders      Order[]
}

model Course {
  id           String     @id @default(cuid())
  name         String
  sortOrder    Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItem {
  id           String     @id @default(cuid())
  name         String
  description  String?
  pricePaise   Int
  discountPercent Int      @default(0)
  imageUrl     String?
  available    Boolean    @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Restrict)
  orderItems   OrderItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([courseId])
}

model OrderSession {
  id        String    @id @default(cuid())
  label     String
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  isOpen    Boolean   @default(true)
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Order {
  id                    String       @id @default(cuid())
  trackingCode          String       @unique
  trackingPasscodeHash  String?
  customerName          String
  customerEmail         String?
  customerPhone         String
  deliveryType          DeliveryType
  hostelBlock           String?
  status                OrderStatus  @default(ORDER_CONFIRMED)
  source                OrderSource
  orderSlot             OrderSlot?
  paymentStatus         PaymentStatus
  subtotalPaise         Int
  platformFeePaise      Int
  hostelFeePaise        Int          @default(0)
  couponCode            String?
  couponDiscountPaise   Int          @default(0)
  paymentFeePaise       Int          @default(0)
  totalPaise            Int
  deliveryReleased      Boolean      @default(false)
  releasedAt            DateTime?
  reachedCampusAt       DateTime?
  deliveredAt           DateTime?
  deliveredById         String?
  deliveredBy           User?        @relation("DeliveredBy", fields: [deliveredById], references: [id])
  restaurantId          String
  restaurant            Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  sessionId             String
  session               OrderSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  items                 OrderItem[]
  payment               Payment?
  rating                Rating?
  // Links the order to the Customer spine. Nullable so an order is never blocked by
  // a missing customer row; populated from the normalized phone on every write.
  customerId            String?
  customer              Customer?    @relation(fields: [customerId], references: [phone], onDelete: SetNull)
  spinRewards           SpinReward[]
  notificationLogs      NotificationLog[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([restaurantId])
  @@index([sessionId])
  @@index([status])
  @@index([customerId])
  @@index([deliveryType, deliveryReleased])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnapshot String
  pricePaise   Int
  quantity     Int
  linePaise    Int

  @@index([orderId])
  @@index([menuItemId])
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider           String        @default("razorpay")
  razorpayOrderId    String?
  razorpayPaymentId  String?
  razorpaySignature  String?
  status             PaymentStatus @default(PENDING)
  amountPaise        Int
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Rating {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodRating     Int
  deliveryRating Int
  review         String?
  createdAt      DateTime @default(now())
}

model NotificationLog {
  id           String              @id @default(cuid())
  orderId      String?
  order        Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel      NotificationChannel
  event        NotificationEvent
  status       NotificationStatus
  errorMessage String?
  sentAt       DateTime            @default(now())
  retryCount   Int                 @default(0)
  nextRetryAt  DateTime?
  lastRetryAt  DateTime?
  resolvedAt   DateTime?

  @@index([orderId])
  @@index([channel, event])
  @@index([status, nextRetryAt])
}

model SystemSettings {
  id                       String   @id @default("default")
  ordersOpen               Boolean  @default(true)
  closedMessage            String   @default("Orders are closed for today.")
  contactNumber            String   @default("Contact admin")
  platformFeePaise         Int      @default(200)
  hostelDeliveryFeePaise   Int      @default(1500)
  paymentChargePercentBps  Int      @default(250)
  paymentChargeFixedPaise  Int      @default(0)
  notifyEmail              Boolean  @default(true)
  notifyWhatsapp           Boolean  @default(true)
  orderingOpenMinute       Int      @default(360)
  orderingCloseMinute      Int      @default(1380)
  spinWheelForEveryone     Boolean  @default(false)
  // IST day (YYYY-MM-DD) whose ordering-window close ends the everyone-mode promo,
  // computed when it is switched on. Enabling after the window has already closed
  // rolls this to the next day so the promo always gets a real day of traffic. A
  // background job flips the promo off once this day's close passes, so it can never
  // be left on by accident.
  spinWheelEveryoneUntilDay String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  discountPercent Int
  active          Boolean  @default(true)
  maxUses         Int?
  usedCount       Int      @default(0)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// A returning customer (identified by phone) who has placed enough *reviewed*
// orders may spin the discount wheel. The won discount is issued as a one-time
// Coupon (couponCode) so it flows through the normal checkout. Each spin is one row
// (a log); a partial unique index (phone WHERE redeemedAt IS NULL, defined in the
// migration) allows at most one active, unredeemed/unexpired reward per phone.
model SpinReward {
  id              String    @id @default(cuid())
  phone           String
  email           String?
  name            String?
  discountPercent Int
  couponCode      String
  createdAt       DateTime  @default(now())
  redeemedAt      DateTime?
  expiredAt       DateTime?
  // The order this reward was actually spent on, set at redemption. Previously this
  // could only be reconstructed by string-matching couponCode against Order.
  orderId         String?
  // The customer's spinBaseline immediately before this reward was redeemed. Redeeming
  // moves the baseline to an absolute count, so this is the only way to restore the
  // exact previous cycle if the order is later cancelled.
  baselineBefore  Int?

  customer        Customer  @relation(fields: [phone], references: [phone], onDelete: Cascade)
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([couponCode])
  @@index([orderId])
}

// One authoritative wheel decision per normalized phone number and IST calendar
// day. Both spinning and deliberately forfeiting create a row, and the compound
// unique constraint makes the daily limit safe under concurrent requests.
// Whether the customer took their daily spin or gave it up by closing the wheel.
enum SpinOutcome {
  SPUN
  FORFEITED
}

// Which rule granted the spin: the 3-reviewed-orders loyalty loop, or the admin's
// "wheel for everyone" promo. Recorded per spin so promo days stay auditable.
enum SpinMode {
  REGULARS
  EVERYONE
}

model SpinUsage {
  id        String      @id @default(cuid())
  phone     String
  spinDay   String
  outcome   SpinOutcome
  mode      SpinMode
  createdAt DateTime    @default(now())

  customer  Customer    @relation(fields: [phone], references: [phone], onDelete: Cascade)

  @@unique([phone, spinDay])
  @@index([spinDay])
}

// Per-phone loyalty baseline. The wheel-eligibility count is (reviewed orders -
// spinBaseline), so redeeming a wheel coupon can reset the eligibility counter to
// zero (by setting spinBaseline to the current reviewed-order count) WITHOUT ever
// deleting or altering the customer's real order history.
// One row per customer, keyed by their normalized 10-digit phone. This is the spine
// everything else hangs off: orders, spins and rewards all point here. Counts ("how
// many orders so far", "how many reviewed") are deliberately NOT stored — they are
// derived from Order/Rating so they can never drift when an order is cancelled.
model Customer {
  phone         String       @id
  name          String?
  email         String?
  // Reviewed-order count at the customer's last claimed/forfeited spin. Wheel
  // eligibility uses (reviewed orders - spinBaseline), so it restarts at 0 each cycle.
  spinBaseline  Int          @default(0)
  // Vestigial: written on spin/forfeit as an audit breadcrumb but NOT read by any
  // eligibility check. Do not add logic that depends on this field.
  wheelConsumed Boolean      @default(false)
  firstSeenAt   DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders        Order[]
  spins         SpinUsage[]
  rewards       SpinReward[]
}
